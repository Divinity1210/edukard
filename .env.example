# =============================================================================
# EduKard — Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real secrets.
#
# The app boots with only the CORE Supabase block set. Every integration below
# is optional and "key-pluggable": leave it blank and that feature degrades
# gracefully; add the key and it activates with no code change.
# =============================================================================

# ---- CORE: Supabase (REQUIRED) ---------------------------------------------
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — Project Settings → API → service_role secret.
# Server-only. Required for webhooks and privileged writes. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ---- APP -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Stripe — payments, PAD (pre-authorized debit) -------------------------
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Create at https://dashboard.stripe.com/test/webhooks → endpoint /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Plaid — bank link, payroll, income verification -----------------------
# https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=sandbox
PLAID_WEBHOOK_SECRET=...

# ---- Circle — USDC custodial wallets + payouts (blockchain layer) ----------
# https://app-sandbox.circle.com/ (sandbox is free)
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_ENV=sandbox
CIRCLE_WEBHOOK_SECRET=...
# Protocol treasury wallet that funds tuition disbursements (Circle wallet id)
CIRCLE_TREASURY_WALLET_ID=...

# ---- Sumsub — KYC / KYB / liveness -----------------------------------------
# https://cockpit.sumsub.com/ → Dev space → App Tokens
SUMSUB_APP_TOKEN=sbx:...
SUMSUB_SECRET_KEY=...
SUMSUB_WEBHOOK_SECRET=...
